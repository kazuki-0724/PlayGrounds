+from flask import Blueprint, jsonify, request
+
+bp = Blueprint("users", __name__)
+
+_USERS = [
+    {"id": 1, "name": "Mika", "role": "admin", "active": True},
+    {"id": 2, "name": "Ren", "role": "viewer", "active": True},
+    {"id": 3, "name": "Sara", "role": "editor", "active": False},
+]
+
+_ALLOWED_ROLES = {"admin", "editor", "viewer"}
+
+
+def _validate_payload(payload):
+    name = (payload.get("name") or "").strip()
+    role = payload.get("role") or "viewer"
+
+    if not name:
+        return "name is required"
+
+    if role not in _ALLOWED_ROLES:
+        return "role is invalid"
+
+    return None
+
+
+@bp.get("/users")
+def list_users():
+    include_inactive = request.args.get("include_inactive") == "true"
+    if include_inactive:
+        return jsonify(_USERS)
+    return jsonify([user for user in _USERS if user["active"]])
+
+
+@bp.get("/users/<int:user_id>")
+def get_user(user_id):
+    user = next((item for item in _USERS if item["id"] == user_id), None)
+    if user is None:
+        return jsonify({"error": "not found"}), 404
+    return jsonify(user)
+
+
+@bp.post("/users")
+def create_user():
+    payload = request.get_json() or {}
+    error = _validate_payload(payload)
+    if error:
+        return jsonify({"error": error}), 400
+
+    next_id = max(user["id"] for user in _USERS) + 1
+    user = {
+        "id": next_id,
+        "name": payload["name"].strip(),
+        "role": payload.get("role", "viewer"),
+        "active": payload.get("active", True),
+    }
+    _USERS.append(user)
+    return jsonify(user), 201
