+
+type ReportJob struct {
+    Name        string
+    Writer      ReportWriter
+    MaxDuration time.Duration
+}
+
+func (job ReportJob) Run(ctx context.Context) error {
+    startedAt := time.Now()
+    log.Printf("job=%s started=%s", job.Name, startedAt.Format(time.RFC3339))
+
+    jobCtx := ctx
+    if job.MaxDuration > 0 {
+        var cancel context.CancelFunc
+        jobCtx, cancel = context.WithTimeout(ctx, job.MaxDuration)
+        defer cancel()
+    }
+
+    if err := job.Writer.Write(jobCtx, startedAt); err != nil {
+        log.Printf("job=%s failed=%v", job.Name, err)
+        return err
+    }
+
+    log.Printf("job=%s completed duration=%s", job.Name, time.Since(startedAt))
+    return nil
+}
