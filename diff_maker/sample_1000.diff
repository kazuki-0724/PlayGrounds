+#!/usr/bin/env bash
+set -euo pipefail
+
+APP_NAME="operations-console"
+BUILD_DIR="dist"
+TARGET_HOST="deploy@example.internal"
+SERVICE_NAME="nginx"
+RELEASE_DIR="/var/www/$APP_NAME/releases"
+STAMP="$(date +%Y%m%d%H%M%S)"
+CURRENT_LINK="/var/www/$APP_NAME/current"
+
+npm ci
+npm run build
+ssh "$TARGET_HOST" "mkdir -p '$RELEASE_DIR/$STAMP'"
+rsync -av --delete "$BUILD_DIR/" "$TARGET_HOST:$RELEASE_DIR/$STAMP/"
+ssh "$TARGET_HOST" "ln -sfn '$RELEASE_DIR/$STAMP' '$CURRENT_LINK'"
+ssh "$TARGET_HOST" "sudo systemctl reload $SERVICE_NAME"
+
+echo "Deployment completed: $STAMP"
