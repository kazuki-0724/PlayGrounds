+use std::sync::Mutex;
+
+#[derive(Default)]
+struct SessionState {
+    counter: u32,
+    last_user: Option<String>,
+    window_title: String,
+}
+
+struct AppState {
+    session: Mutex<SessionState>,
+}
+
+fn increment(state: tauri::State<AppState>, user: String) -> u32 {
+    let mut session = state.session.lock().unwrap();
+    session.counter += 1;
+    session.last_user = Some(user);
+    session.counter
+}
+
+fn update_title(state: tauri::State<AppState>, title: String) {
+    let mut session = state.session.lock().unwrap();
+    session.window_title = title;
+}
+
+fn current_user(state: tauri::State<AppState>) -> String {
+    let session = state.session.lock().unwrap();
+    session.last_user.clone().unwrap_or_else(|| "guest".into())
+}
+
+fn main() {
+    tauri::Builder::default()
+        .manage(AppState {
+            session: Mutex::new(SessionState {
+                window_title: String::from("Operations Console"),
+                ..SessionState::default()
+            }),
+        })
+        .invoke_handler(tauri::generate_handler![increment, update_title, current_user])
+        .run(tauri::generate_context!())
+        .expect("error while running app");
+}
