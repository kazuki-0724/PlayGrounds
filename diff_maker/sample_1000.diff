+import { createRouter } from './router';
+import { renderDashboard } from './dashboard';
+import { renderSettings } from './settings';
+import { createStore } from './store';
+import { createApiClient } from './api';
+
+const root = document.getElementById('app');
+const store = createStore({
+  theme: 'light',
+  notifications: [],
+  summary: null
+});
+const api = createApiClient('/api');
+
+function setStatus(message, type = 'info') {
+  const status = document.getElementById('status');
+  if (status) {
+    status.dataset.type = type;
+    status.textContent = message;
+  }
+}
+
+async function loadSummary() {
+  setStatus('Loading summary');
+  const [summary, notifications] = await Promise.all([
+    api.get('/summary'),
+    api.get('/notifications')
+  ]);
+  store.set('summary', summary);
+  store.set('notifications', notifications);
+  setStatus('Summary loaded');
+}
+
+function renderPage(route) {
+  if (!root) {
+    return;
+  }
+
+  root.innerHTML = '';
+
+  switch (route.name) {
+    case 'dashboard':
+      root.appendChild(renderDashboard(store));
+      break;
+    case 'settings':
+      root.appendChild(renderSettings(store));
+      break;
+    default: {
+      const empty = document.createElement('section');
+      empty.className = 'empty-state';
+      empty.textContent = 'Select a page from the navigation';
+      root.appendChild(empty);
+    }
+  }
+}
+
+function bootstrap() {
+  const router = createRouter();
+  router.onChange((route) => {
+    store.set('lastRoute', route.name);
+    store.set('lastVisitedAt', new Date().toISOString());
+    renderPage(route);
+  });
+
+  loadSummary().catch((error) => {
+    console.error(error);
+    setStatus('Failed to load summary', 'error');
+  });
+
+  router.start();
+}
+
+bootstrap();
